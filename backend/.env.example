# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/StockDB

# Security & CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Settings
FLASK_ENV=production
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false
APP_USE_RELOADER=false
APP_THREADED=true
SECRET_KEY=your-secret-key-here

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# News API Keys (Optional - enables news features)
# Get your free API key from: https://newsapi.org/
NEWSAPI_KEY=

# Finnhub API Key (Optional - stock-specific news)
# Get your free API key from: https://finnhub.io/
FINNHUB_KEY=

# Alpha Vantage API Key (Optional - news with sentiment)
# Get your free API key from: https://www.alphavantage.co/
ALPHAVANTAGE_KEY=

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=16
SCHEDULER_MINUTE=0
SCHEDULER_AUTO_START=true
SCHEDULER_AUTO_CATCHUP=false
SCHEDULER_AUTO_TRAIN=false
# Keep false for multi-worker gunicorn deployments; enable only with a single web worker.
SCHEDULER_IN_WEB_WORKER=false
